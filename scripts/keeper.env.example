# Required
RPC_URL=https://your-monad-rpc
PRIVATE_KEY=0xyour_private_key
POOL_ADDRESS=0xyour_pool_address

# Optional
KEEPER_INTERVAL_MS=30000
KEEPER_DRY_RUN=false
KEEPER_GAS_LIMIT=
KEEPER_MAX_FEE_GWEI=
KEEPER_MAX_PRIORITY_FEE_GWEI=

# Keeper safety/alerts
KEEPER_LOW_BALANCE_MON=0.2
KEEPER_ERROR_ALERT_THRESHOLD=3
KEEPER_BALANCE_LOG_EVERY_TICKS=20
KEEPER_HEARTBEAT_LOG_EVERY_TICKS=10
KEEPER_PREFLIGHT=true

# Telegram alerts (optional but recommended)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TIMEOUT_MS=8000
TELEGRAM_RETRIES=2
